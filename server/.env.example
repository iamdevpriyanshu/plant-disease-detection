# Copy to .env and fill secrets (never commit .env)

# Max upload size in bytes (default ~150KB; Android client targets ≤100KB JPEG)
# MAX_UPLOAD_BYTES=153600

# Classifier + API metadata
# CLASSIFIER_VERSION=stub-1.0

# OpenAI-compatible API (set key to enable causes / treatment text)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60

# Comma-separated origins or * for all (dev only)
CORS_ORIGINS=*
